# ==================================================
# COLABORAPANC - Environment Configuration Template
# ==================================================
# Copy this file to .env and replace placeholders.
# Never commit real credentials.

# --------------------------------------------------
# REQUIRED - DJANGO CORE
# --------------------------------------------------
DJANGO_SECRET_KEY=[REQUIRED_CHANGE_IN_PRODUCTION]
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SITE_ID=1

# --------------------------------------------------
# REQUIRED - DATABASE (PostgreSQL + PostGIS)
# --------------------------------------------------
POSTGRES_DB=pancdb
POSTGRES_USER=pancuser
POSTGRES_PASSWORD=[REQUIRED]
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --------------------------------------------------
# OPTIONAL - EMAIL (development default uses console backend)
# --------------------------------------------------
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.org
DJANGO_EMAIL_VERIFICATION=optional

# --------------------------------------------------
# OPTIONAL - CORS / MOBILE BASE URL
# --------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=False
EXPO_PUBLIC_API_URL=http://localhost:8000

# --------------------------------------------------
# OPTIONAL EXTERNAL INTEGRATIONS (set only if used)
# --------------------------------------------------
# Plant identification providers
PLANTID_API_KEY=[OPTIONAL_EXTERNAL]
PLANTNET_API_KEY=[OPTIONAL_EXTERNAL]

# Geocoding
LOCATIONIQ_API_KEY=[OPTIONAL_EXTERNAL]

# MapBiomas
MAPBIOMAS_EMAIL=[OPTIONAL_EXTERNAL]
MAPBIOMAS_PASSWORD=[OPTIONAL_EXTERNAL]

# Botanical enrichment providers
ENRICH_HTTP_TIMEOUT=8
ENRICH_HTTP_RETRIES=2
ENRICH_CACHE_TTL_GNV=86400
ENRICH_CACHE_TTL_TROPICOS=86400
ENRICH_CACHE_TTL_GBIF=3600
ENRICH_CACHE_TTL_INAT=3600
ENRICH_CACHE_TTL_TREFLE=43200
ENRICH_CACHE_TTL_WIKIMEDIA=86400

GNAMES_API_URL=https://verifier.globalnames.org/api/v1
TROPICOS_API_URL=https://services.tropicos.org
TROPICOS_API_KEY=[OPTIONAL_EXTERNAL]
GBIF_API_URL=https://api.gbif.org/v1
INAT_API_URL=https://api.inaturalist.org/v1
TREFLE_API_URL=https://trefle.io/api/v1
TREFLE_TOKEN=[OPTIONAL_EXTERNAL]
TREFLE_API_TOKEN=[OPTIONAL_EXTERNAL]

# Environmental providers
NASA_FIRMS_MAP_KEY=[OPTIONAL_EXTERNAL]
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
NASA_FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api/area/csv
INMET_RSS_URL=https://apiprevmet3.inmet.gov.br/
OPENMETEO_API_URL=https://api.open-meteo.com/v1/forecast

# Wikimedia / Wikipedia enrichment
COLABORAPANC_VERSION=1.0
WIKIMEDIA_USER=[OPTIONAL_EXTERNAL]
WIKIMEDIA_EMAIL=[OPTIONAL_EXTERNAL]
WIKIMEDIA_USER_AGENT=ColaboraPANC/1.0 ([OPTIONAL_EXTERNAL])
WIKIMEDIA_API_USER_AGENT=ColaboraPANC/1.0 ([OPTIONAL_EXTERNAL])
WIKIMEDIA_ENRICHMENT_ENABLED=True
WIKIMEDIA_TIMEOUT_SECONDS=8
WIKIMEDIA_HTTP_RETRIES=2
WIKIMEDIA_MIN_MATCH_CONFIDENCE=0.55

# --------------------------------------------------
# Demo mode note
# --------------------------------------------------
# For local demo runs, keep optional integrations unset and rely on
# internal/test flows whenever available.
